{
  "name": "osteojp-platform",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "turbo run build",
    "db:check": "pnpm --filter @osteojp/db exec drizzle-kit check",
    "db:migrate": "pnpm --filter @osteojp/db exec drizzle-kit migrate",
    "db:studio": "pnpm --filter @osteojp/db exec drizzle-kit studio",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "2.9.14",
    "typescript": "5.9.3"
  }
}
