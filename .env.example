# ---------------------------------------------------------------------------
# Public — safe to expose to the browser (Next.js NEXT_PUBLIC_* convention)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Server-only — never expose these to the client or commit real values
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Direct 5432 connection for drizzle-kit migrate (transaction pooler does not support session advisory locks).
DATABASE_URL_DIRECT=

# ---------------------------------------------------------------------------
# Sentry — error monitoring (apps/web). EU region project.
# ---------------------------------------------------------------------------
# Public DSN used by the browser SDK (instrumentation-client.ts).
NEXT_PUBLIC_SENTRY_DSN=
# Server/edge DSN used by sentry.server.config.ts and sentry.edge.config.ts.
SENTRY_DSN=
# Auth token for source-map upload during `next build` (CI only, do not commit).
SENTRY_AUTH_TOKEN=
# Sentry organization slug (e.g. osteojp).
SENTRY_ORG=
# Sentry project slug (e.g. web).
SENTRY_PROJECT=
