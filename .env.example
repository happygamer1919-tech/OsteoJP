# OsteoJP — environment variable reference.
#
# Copy this file to `.env` (or `.env.local` for Next apps) and fill in real
# values. Never commit real secrets. EU data-residency: all stored-data
# services must be EU-region (Supabase Frankfurt, Resend EU, Vercel fra1).
#
# REQUIRED FOR LOCAL DEV:  DATABASE_URL only.
# Every other section is wired up phase-by-phase; leave them blank until the
# feature lands. Production deploys must set every variable in the section
# whose feature is enabled.

# ---------------------------------------------------------------------------
# Supabase (dev)
# ---------------------------------------------------------------------------
# Postgres connection string. Prefer the Supabase session-pooler URI for the
# app runtime; `drizzle-kit migrate` works against pooled or direct.
DATABASE_URL=

# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Anonymous public key. Used by the browser SDK; safe to expose to the client.
SUPABASE_ANON_KEY=

# Service-role key. Bypasses RLS — admin scripts and migrations ONLY.
# NEVER ship this to the client or to a browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# AI partner ingestion
# ---------------------------------------------------------------------------
# Bearer credential the partner presents on the ingestion endpoint.
AI_INGESTION_API_KEY=

# Shared secret used to verify the HMAC signature on each ingested payload.
AI_INGESTION_HMAC_SECRET=

# ---------------------------------------------------------------------------
# Email and SMS
# ---------------------------------------------------------------------------
# Resend (EU region) — transactional email.
RESEND_API_KEY=

# Twilio — SMS reminders and notifications.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# Payments
# ---------------------------------------------------------------------------
# Stripe — card payments (Phase 4+).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# IfThenPay — Portuguese Multibanco / MB WAY rails.
IFTHENPAY_BACKOFFICE_KEY=
IFTHENPAY_MB_ENTITY=
IFTHENPAY_MB_SUBENTITY=
IFTHENPAY_MBWAY_KEY=

# ---------------------------------------------------------------------------
# Invoicing
# ---------------------------------------------------------------------------
# InvoiceXpress — AT-certified Portuguese fiscal-document relay (Phase 4).
INVOICEXPRESS_ACCOUNT_NAME=
INVOICEXPRESS_API_KEY=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
# Sentry (EU) — runtime error tracking. Project-level DSN.
SENTRY_DSN=

# Sentry auth token — sourcemap uploads at build time. Server/CI only.
SENTRY_AUTH_TOKEN=
