# ---------------------------------------------------------------------------
# Public — safe to expose to the browser (Next.js NEXT_PUBLIC_* convention)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Server-only — never expose these to the client or commit real values
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Supabase SESSION pooler (...pooler.supabase.com:5432) for drizzle-kit migrate (transaction pooler does not support session advisory locks). Not the db.<ref>.supabase.co direct host (IPv4-gated).
DATABASE_URL_DIRECT=

# ---------------------------------------------------------------------------
# Sentry — error monitoring (apps/web). EU region project.
# ---------------------------------------------------------------------------
# Public DSN used by the browser SDK (instrumentation-client.ts).
NEXT_PUBLIC_SENTRY_DSN=
# Server/edge DSN used by sentry.server.config.ts and sentry.edge.config.ts.
SENTRY_DSN=
# Auth token for source-map upload during `next build` (CI only, do not commit).
SENTRY_AUTH_TOKEN=
# Sentry organization slug (e.g. osteojp).
SENTRY_ORG=
# Sentry project slug (e.g. web).
SENTRY_PROJECT=

# ---------------------------------------------------------------------------
# Reminders (Stream E) — appointment reminder jobs. SANDBOX by default.
# ---------------------------------------------------------------------------
# Master switch for LIVE sends. Sandbox unless set to exactly "true": reminders
# render and log but make ZERO network calls. Flip to "true" only in prod after
# the Resend domain and Twilio sender are verified.
REMINDERS_LIVE_SEND=
# Base URL for the reschedule short-link in reminder EMAIL copy. The link resolves
# at <base>/r/<token>. Defaults to https://osteojp.pt.
REMINDERS_RESCHEDULE_BASE_URL=
# Secret for HMAC-signing the stateless reschedule short-link token (/r/<token>).
# Required to mint links; signing fails loud if unset. Use a long random value
# (e.g. `openssl rand -base64 32`). Server-only — NEVER expose or log it.
REMINDERS_LINK_SECRET=

# Inngest — background job orchestration (apps/web /api/inngest). The local
# Inngest Dev Server needs neither key; both are required in deployed envs.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend — transactional email (EU region). Sandbox/test key until the osteojp.pt
# domain is verified. Never commit a real key.
RESEND_API_KEY=
# Verified sender address (pending domain verification).
REMINDERS_EMAIL_FROM=

# Twilio — transactional SMS (PT sender). Test credentials until the alphanumeric
# sender ID is registered for Portugal. Never commit real values.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Either a from-number or a Messaging Service SID (from-number takes precedence).
TWILIO_SMS_FROM=
TWILIO_MESSAGING_SERVICE_SID=
