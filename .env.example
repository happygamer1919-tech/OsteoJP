# ---------------------------------------------------------------------------
# Public — safe to expose to the browser (Next.js NEXT_PUBLIC_* convention)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Server-only — never expose these to the client or commit real values
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Direct (port 5432) connection for drizzle-kit migrate — the Supabase transaction pooler (6543) does not support the session advisory locks migrations need.
DATABASE_URL_DIRECT=
