# ---------------------------------------------------------------------------
# Public — safe to expose to the browser (Next.js NEXT_PUBLIC_* convention)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Browser-side Sentry DSN (same DSN as SENTRY_DSN; exposed because client init reads it).
NEXT_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Server-only — never expose these to the client or commit real values
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Direct 5432 connection for drizzle-kit migrate (transaction pooler does not support session advisory locks).
DATABASE_URL_DIRECT=

# Sentry — server/edge init + sourcemap upload at build time.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
