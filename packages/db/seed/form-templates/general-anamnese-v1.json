{
  "key": "ficha_geral",
  "version": 1,
  "title": {
    "pt": "Ficha Geral",
    "en": "General Intake Form"
  },
  "x-form-note": "Shared general anamnese filled once per new patient (or once per new episode if clinically significant time has passed). Covers identity, contacts, RGPD consent, health history, medication, allergies. Does NOT include therapy-specific clinical fields — those are in the therapy supplement forms.",
  "x-fires-on": "first_visit_or_new_episode",
  "x-authored-by": "Max (sm33xy)",
  "x-confirmed-by": "João Pedro (owner) — 2026-06-03 batch response Q5",
  "sections": [
    {
      "key": "section_personal",
      "title": { "pt": "Dados Pessoais", "en": "Personal Details" },
      "fields": [
        {
          "key": "full_name",
          "type": "text",
          "label": { "pt": "Nome completo", "en": "Full name" },
          "required": true,
          "ai_extractable": false
        },
        {
          "key": "date_of_birth",
          "type": "date",
          "label": { "pt": "Data de nascimento", "en": "Date of birth" },
          "required": true,
          "ai_extractable": false
        },
        {
          "key": "sex",
          "type": "select",
          "label": { "pt": "Sexo biológico", "en": "Biological sex" },
          "options": [
            { "value": "male", "label": { "pt": "Masculino", "en": "Male" } },
            { "value": "female", "label": { "pt": "Feminino", "en": "Female" } },
            { "value": "other", "label": { "pt": "Outro", "en": "Other" } },
            { "value": "not_specified", "label": { "pt": "Não especificado", "en": "Not specified" } }
          ],
          "required": true,
          "ai_extractable": false
        },
        {
          "key": "nif",
          "type": "text",
          "label": { "pt": "NIF", "en": "NIF (tax number)" },
          "hint": { "pt": "Necessário para emissão de fatura.", "en": "Required for invoice generation." },
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "profession",
          "type": "text",
          "label": { "pt": "Profissão", "en": "Profession" },
          "required": false,
          "ai_extractable": false
        }
      ]
    },
    {
      "key": "section_contacts",
      "title": { "pt": "Contactos", "en": "Contacts" },
      "fields": [
        {
          "key": "phone",
          "type": "tel",
          "label": { "pt": "Telemóvel", "en": "Mobile" },
          "required": true,
          "ai_extractable": false
        },
        {
          "key": "email",
          "type": "email",
          "label": { "pt": "Email", "en": "Email" },
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "address",
          "type": "text",
          "label": { "pt": "Morada", "en": "Address" },
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "emergency_contact_name",
          "type": "text",
          "label": { "pt": "Contacto de emergência — Nome", "en": "Emergency contact — Name" },
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "emergency_contact_phone",
          "type": "tel",
          "label": { "pt": "Contacto de emergência — Telemóvel", "en": "Emergency contact — Mobile" },
          "required": false,
          "ai_extractable": false
        }
      ]
    },
    {
      "key": "section_health",
      "title": { "pt": "Historial de Saúde", "en": "Health History" },
      "fields": [
        {
          "key": "general_health",
          "type": "select",
          "label": { "pt": "Estado geral de saúde", "en": "General health status" },
          "options": [
            { "value": "excellent", "label": { "pt": "Excelente", "en": "Excellent" } },
            { "value": "good", "label": { "pt": "Bom", "en": "Good" } },
            { "value": "fair", "label": { "pt": "Razoável", "en": "Fair" } },
            { "value": "poor", "label": { "pt": "Mau", "en": "Poor" } }
          ],
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "chronic_conditions",
          "type": "checkbox_group",
          "label": { "pt": "Condições de saúde crónicas (assinale as que se aplicam)", "en": "Chronic health conditions (check all that apply)" },
          "options": [
            { "value": "diabetes", "label": { "pt": "Diabetes", "en": "Diabetes" } },
            { "value": "hypertension", "label": { "pt": "Hipertensão", "en": "Hypertension" } },
            { "value": "heart_disease", "label": { "pt": "Doença cardíaca", "en": "Heart disease" } },
            { "value": "respiratory", "label": { "pt": "Doença respiratória", "en": "Respiratory disease" } },
            { "value": "osteoporosis", "label": { "pt": "Osteoporose", "en": "Osteoporosis" } },
            { "value": "cancer", "label": { "pt": "Oncologia (atual ou passada)", "en": "Oncology (current or past)" } },
            { "value": "neurological", "label": { "pt": "Doença neurológica", "en": "Neurological condition" } },
            { "value": "autoimmune", "label": { "pt": "Doença autoimune", "en": "Autoimmune condition" } },
            { "value": "none", "label": { "pt": "Nenhuma", "en": "None" } }
          ],
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "previous_surgeries",
          "type": "textarea",
          "label": { "pt": "Cirurgias anteriores (descreva, com datas aproximadas)", "en": "Previous surgeries (describe, with approximate dates)" },
          "required": false,
          "ai_extractable": true
        },
        {
          "key": "fractures_injuries",
          "type": "textarea",
          "label": { "pt": "Fraturas ou lesões relevantes", "en": "Relevant fractures or injuries" },
          "required": false,
          "ai_extractable": true
        },
        {
          "key": "pregnancy",
          "type": "select",
          "label": { "pt": "Gravidez", "en": "Pregnancy" },
          "options": [
            { "value": "na", "label": { "pt": "Não aplicável", "en": "Not applicable" } },
            { "value": "t1", "label": { "pt": "1.º trimestre", "en": "1st trimester" } },
            { "value": "t2", "label": { "pt": "2.º trimestre", "en": "2nd trimester" } },
            { "value": "t3", "label": { "pt": "3.º trimestre", "en": "3rd trimester" } },
            { "value": "postpartum", "label": { "pt": "Pós-parto (menos de 6 semanas)", "en": "Postpartum (less than 6 weeks)" } }
          ],
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "implants",
          "type": "textarea",
          "label": { "pt": "Implantes ou próteses (tipo e localização)", "en": "Implants or prosthetics (type and location)" },
          "hint": { "pt": "Ex: pacemaker, prótese da anca, implante dentário.", "en": "E.g. pacemaker, hip prosthesis, dental implant." },
          "required": false,
          "ai_extractable": false
        }
      ]
    },
    {
      "key": "section_medication",
      "title": { "pt": "Medicação Atual", "en": "Current Medication" },
      "fields": [
        {
          "key": "medication",
          "type": "textarea",
          "label": { "pt": "Medicação atual (nome e dosagem)", "en": "Current medication (name and dosage)" },
          "placeholder": { "pt": "Ex: Metformina 500mg, Omeprazol 20mg", "en": "E.g. Metformin 500mg, Omeprazole 20mg" },
          "ai_extractable": false,
          "required": false
        },
        {
          "key": "medication_none",
          "type": "checkbox",
          "label": { "pt": "Não tomo medicação", "en": "I am not taking any medication" },
          "required": false,
          "ai_extractable": false
        }
      ]
    },
    {
      "key": "section_allergies",
      "title": { "pt": "Alergias", "en": "Allergies" },
      "fields": [
        {
          "key": "allergies",
          "type": "textarea",
          "label": { "pt": "Alergias conhecidas (medicamentos, materiais, substâncias)", "en": "Known allergies (medications, materials, substances)" },
          "required": false,
          "ai_extractable": false
        },
        {
          "key": "allergies_none",
          "type": "checkbox",
          "label": { "pt": "Sem alergias conhecidas", "en": "No known allergies" },
          "required": false,
          "ai_extractable": false
        }
      ]
    },
    {
      "key": "section_consent",
      "title": { "pt": "Consentimento", "en": "Consent" },
      "fields": [
        {
          "key": "consent_treatment",
          "type": "checkbox",
          "label": { "pt": "Consinto a realização do tratamento proposto pela clínica OsteoJP.", "en": "I consent to the proposed treatment by OsteoJP clinic." },
          "required": true,
          "ai_extractable": false
        },
        {
          "key": "consent_data",
          "type": "checkbox",
          "label": { "pt": "Consinto o tratamento dos meus dados pessoais para fins clínicos, nos termos do RGPD (Regulamento Geral sobre a Proteção de Dados).", "en": "I consent to the processing of my personal data for clinical purposes, in accordance with GDPR." },
          "required": true,
          "ai_extractable": false
        },
        {
          "key": "consent_reminders",
          "type": "checkbox",
          "label": { "pt": "Autorizo o envio de lembretes de consulta por SMS e/ou email.", "en": "I authorise the sending of appointment reminders by SMS and/or email." },
          "required": false,
          "ai_extractable": false
        }
      ]
    }
  ],
  "_meta": {
    "source": "JP decision 2026-06-03 batch Q5 — shared anamnese fires once per new patient or new episode",
    "reviewed_by": "Max (sm33xy)",
    "version_note": "v1 — general anamnese, no therapy-specific clinical fields"
  }
}
