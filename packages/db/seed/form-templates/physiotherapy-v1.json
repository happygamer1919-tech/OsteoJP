{
  "key": "physiotherapy",
  "version": 2,
  "title": {
    "pt": "Fisioterapia — Avaliação de Episódio",
    "en": "Physiotherapy — Episode Evaluation"
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Clinical intake form for a physiotherapy episode. Field structure transcribed from the Fisiozero physiotherapy episode form (NOVO EPISODIO, Fisioterapia) as seen in production screenshots (2026-05-25). This form is deliberately simpler than the osteopathy form — no Problemas de Saúde checkboxes and no Anamnese por Sistemas. PT is the source language; EN labels provided for the bilingual UI. ai_extractable is false on every field pending the AI-partner contract.",
    "type": "object",
    "required": ["episode_date", "main_complaints"],
    "properties": {
      "episode_date": {
        "type": "string",
        "format": "date",
        "x-label": { "pt": "Data do Episódio", "en": "Episode Date" },
        "x-required": true,
        "ai_extractable": false
      },
      "weight_kg": {
        "type": ["number", "null"],
        "minimum": 0,
        "x-label": { "pt": "Peso (kg)", "en": "Weight (kg)" },
        "ai_extractable": false
      },
      "height_cm": {
        "type": ["number", "null"],
        "minimum": 0,
        "x-label": { "pt": "Altura (cm)", "en": "Height (cm)" },
        "ai_extractable": false
      },
      "linked_appointment": {
        "type": ["string", "null"],
        "x-label": { "pt": "Marcação respectiva", "en": "Linked Appointment" },
        "x-widget": "appointment_picker",
        "ai_extractable": false
      },
      "cid_codes": {
        "type": "array",
        "items": { "type": "string" },
        "x-label": { "pt": "Códigos CID associados", "en": "Associated ICD Codes" },
        "ai_extractable": false
      },
      "red_flags": {
        "type": ["string", "null"],
        "x-label": { "pt": "Alertas Red Flags", "en": "Red Flags" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "main_complaints": {
        "type": "string",
        "x-label": { "pt": "Principais Queixas", "en": "Main Complaints" },
        "x-widget": "textarea",
        "x-required": true,
        "ai_extractable": false
      },
      "background": {
        "type": ["string", "null"],
        "x-label": { "pt": "Antecedentes", "en": "Background / History" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "medication": {
        "type": ["string", "null"],
        "x-label": { "pt": "Medicação", "en": "Medication" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "diagnosis": {
        "type": ["string", "null"],
        "x-label": { "pt": "Diagnóstico", "en": "Diagnosis" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "bodychart": {
        "type": ["object", "null"],
        "x-label": { "pt": "Bodychart", "en": "Body Chart" },
        "x-widget": "bodychart",
        "ai_extractable": false
      },
      "treatment_goals": {
        "type": ["string", "null"],
        "x-label": { "pt": "Objectivos do Tratamento", "en": "Treatment Goals" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "treatment_plan": {
        "type": ["string", "null"],
        "x-label": { "pt": "Plano de Tratamento", "en": "Treatment Plan" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "observations": {
        "type": ["string", "null"],
        "x-label": { "pt": "Observações", "en": "Observations" },
        "x-widget": "textarea",
        "ai_extractable": false
      },
      "private_notes": {
        "type": ["string", "null"],
        "x-label": { "pt": "Notas Pessoais sobre o Utente neste Episódio / Consulta", "en": "Personal Notes (this episode)" },
        "x-widget": "textarea",
        "x-private": true,
        "x-note": "Este campo não é partilhado com nenhum outro utilizador da sua conta.",
        "ai_extractable": false
      }
    }
  },
  "_meta": {
    "source": "Fisiozero production screenshot 2026-05-25 — Fisioterapia NOVO EPISODIO form",
    "reviewed_by": "Max (sm33xy)",
    "version_note": "v2 corrects v1 which had erroneously included the full Osteopatia field set. Physio form is intentionally simpler: no Problemas de Saúde checkboxes, no Anamnese por Sistemas.",
    "pending_owner": ["Confirm field order is correct", "RPG, massagem terapêutica, pilates terapêutico forms still outstanding"]
  }
}
