                  "en": "Blockage / Dysfunction"
                },
                "scar": {
                  "pt": "Cicatriz",
                  "en": "Scar"
                },
                "hypertonicity": {
                  "pt": "Hipertonicidade",
                  "en": "Hypertonicity"
                },
                "hypotonicity": {
                  "pt": "Hipotonicidade",
                  "en": "Hypotonicity"
                },
                "pain_radiation": {
                  "pt": "Irradiação da dor",
