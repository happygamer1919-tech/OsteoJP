                  "pt": "Parestesia",
                  "en": "Paresthesia"
                },
                "rotation_right": {
                  "pt": "Rotação direita",
                  "en": "Rotation right"
                },
                "rotation_left": {
                  "pt": "Rotação esquerda",
                  "en": "Rotation left"
                }
